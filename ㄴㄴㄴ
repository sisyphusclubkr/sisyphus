<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>시지프스 클럽 - 갓생챌린지 PRO</title>
  
  <script src="https://cdnjs.cloudflare.com/ajax/libs/resemblejs/4.1.0/resemble.min.js"></script>
  
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Noto+Sans+KR:wght@400;700&display=swap" rel="stylesheet">
  
  <style>
    /* Global Styles: Trendy Dark Mode */
    :root {
      --bg-color: #1a1a1a;
      --card-bg: #2d2d2d;
      --accent: #007bff;
      --accent-hover: #0056b3;
      --success: #2ecc71;
      --warning: #f39c12;
      --text-color: #ffffff;
      --text-muted: #aaaaaa;
      --glass: rgba(255, 255, 255, 0.05);
      --font-family: 'Poppins', 'Noto Sans KR', sans-serif;
    }

    body { font-family: var(--font-family); background-color: var(--bg-color); margin: 0; padding: 20px; color: var(--text-color); -webkit-font-smoothing: antialiased; }
    .container { max-width: 500px; margin: 0 auto; padding-bottom: 50px; }
    
    h1 { text-align: center; color: var(--text-color); margin-bottom: 20px; font-size: 26px; font-weight: 700; letter-spacing: -1px; }
    h1 span { color: var(--accent); }
    
    /* Top Noti Button */
    .noti-btn { width: 100%; background: var(--glass); border: 2px solid var(--accent); color: var(--text-color); padding: 14px; border-radius: 12px; font-weight: 600; font-size: 15px; margin-bottom: 30px; cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: center; gap: 8px; }
    .noti-btn:hover { background: var(--accent); }
    
    /* Habit Section: Glassmorphism effect */
    .habit-section { background: var(--card-bg); padding: 20px; border-radius: 20px; margin-bottom: 40px; border: 1px solid var(--glass); box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2); transition: 0.3s; }
    .habit-title { font-size: 19px; color: var(--text-color); margin-top: 0; margin-bottom: 20px; text-align: center; font-weight: 700; display: flex; align-items: center; justify-content: center; gap: 10px; }
    .habit-title i { color: var(--accent); font-size: 1.2em; }
    
    /* Cards with minimal design */
    .card { background: var(--glass); padding: 18px; border-radius: 15px; border: 1px solid rgba(255,255,255,0.03); margin-bottom: 18px; }
    .card h3 { margin-top: 0; font-size: 16px; color: var(--text-muted); margin-bottom: 15px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
    
    /* Trendy Inputs */
    .input-group { margin-bottom: 12px; display: flex; align-items: center; }
    .input-group label { width: 60px; font-weight: 600; color: var(--text-muted); font-size: 14px; }
    .input-group input { flex: 1; padding: 12px 14px; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); border-radius: 10px; color: var(--text-color); outline: none; font-size: 14px; font-family: inherit; transition: 0.2s; }
    .input-group input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.2); }
    
    /* Photo Boxes */
    .photo-container { display: flex; gap: 12px; }
    .photo-box { flex: 1; border: 2px dashed rgba(255,255,255,0.1); padding: 20px 8px; text-align: center; border-radius: 15px; color: var(--text-muted); background-position: center; background-size: cover; background-repeat: no-repeat; min-height: 110px; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; word-break: keep-all; cursor: pointer; transition: 0.3s; }
    .photo-box i { font-size: 1.5em; color: rgba(255,255,255,0.2); }
    .photo-box:hover { border-color: var(--accent); background-color: var(--glass); }
    .result-box { background-color: rgba(0,0,0,0.2); border-style: solid; border-color: rgba(255,255,255,0.05); cursor: default; }
    
    /* Action Button with Icon and Pulse animation */
    .action-btn { width: 100%; padding: 16px; font-size: 17px; font-weight: 700; border: none; border-radius: 12px; cursor: pointer; background-color: var(--accent); color: white; transition: 0.3s; margin-top: 5px; display: flex; align-items: center; justify-content: center; gap: 10px; }
    .action-btn i { font-size: 1.1em; }
    .action-btn:disabled { background-color: var(--glass); color: var(--text-muted); cursor: not-allowed; border: 1px solid rgba(255,255,255,0.03); }
    .action-btn.success { background-color: var(--success); }
    
    input[type="file"] { display: none; }

    /* --- Detailed Result Modal --- */
    .modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.8); backdrop-filter: blur(8px); opacity: 0; transition: opacity 0.3s; }
    .modal-content { background-color: var(--card-bg); margin: 15% auto; padding: 25px; border-radius: 20px; border: 1px solid var(--glass); width: 90%; max-width: 400px; text-align: center; transform: translateY(-50px); transition: transform 0.3s; }
    .modal.show { display: block; opacity: 1; }
    .modal.show .modal-content { transform: translateY(0); }
    .modal h2 { margin-top: 0; font-size: 20px; }
    .modal-result-data { background: rgba(0,0,0,0.2); border-radius: 12px; padding: 15px; margin-top: 15px; margin-bottom: 20px; }
    .modal-result-line { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; font-size: 14px; font-weight: 600; color: var(--text-muted); }
    .modal-result-value { font-size: 16px; font-weight: 700; color: var(--text-color); }
    .modal-result-value.high { color: var(--success); }
    .modal-result-value.low { color: var(--warning); }
    .modal-photo-previews { display: flex; gap: 10px; margin-bottom: 20px; }
    .modal-photo-preview { flex: 1; border: 1px solid var(--glass); border-radius: 10px; background-size: cover; background-position: center; min-height: 80px; }
    .close-modal { width: 100%; background: var(--glass); color: var(--text-color); border: none; padding: 12px; border-radius: 10px; cursor: pointer; font-weight: 600; font-size: 15px; transition: 0.2s; }
    .close-modal:hover { background: rgba(255,255,255,0.1); }

    /* --- Analysis Loading Overlay --- */
    .loading-overlay { display: none; position: fixed; z-index: 2000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.8); backdrop-filter: blur(12px); flex-direction: column; align-items: center; justify-content: center; gap: 20px; opacity: 0; transition: opacity 0.3s; }
    .loading-overlay.show { display: flex; opacity: 1; }
    .spinner { border: 4px solid rgba(255,255,255,0.1); border-top: 4px solid var(--accent); border-radius: 50%; width: 50px; height: 50px; animation: spin 1s linear infinite; }
    .loading-overlay p { color: var(--text-color); font-weight: 600; font-size: 16px; margin: 0; }

    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
  </style>
</head>
<body>

<div class="container">
  <h1><span>🔥</span> 갓생챌린지 PRO</h1>
  
  <button class="noti-btn" onclick="requestNotification()"><i class="icon">🔔</i> 스마트폰 알림 권한 활성화 (필수)</button>

  <div id="habitContainer"></div>
</div>

<div id="resultModal" class="modal">
  <div class="modal-content">
    <h2 id="modalTitle">인증 결과 분석</h2>
    <div class="modal-photo-previews">
      <div id="modalExamplePhoto" class="modal-photo-preview" title="예시 사진"></div>
      <div id="modalResultPhoto" class="modal-photo-preview" title="촬영 사진"></div>
    </div>
    <div class="modal-result-data">
      <div class="modal-result-line"><span>유사도</span> <span id="modalSimilarity" class="modal-result-value">--%</span></div>
      <div class="modal-result-line"><span>불일치율</span> <span id="modalMismatch" class="modal-result-value low">--%</span></div>
      <div class="modal-result-line"><span>분석 시간</span> <span id="modalAnalysisTime" class="modal-result-value">--초</span></div>
    </div>
    <p id="modalMessage" style="font-size: 14px; font-weight: 600; margin-bottom: 25px;"></p>
    <button class="close-modal" id="closeModalBtn" onclick="closeModal()">확인</button>
  </div>
</div>

<div id="loadingOverlay" class="loading-overlay">
  <div class="spinner"></div>
  <p>픽셀 데이터 정밀 분석 중...</p>
</div>

<script>
  // Icon mapping for titles
  const habitIcons = ["📚", "🏃‍♂️", "✍️"];

  const fields = [
    { id: 'wWho', label: '누가', type: 'text', placeholder: '예: 내가' },
    { id: 'wWhen', label: '언제', type: 'time', placeholder: '' },
    { id: 'wWhere', label: '어디서', type: 'text', placeholder: '예: 책상에서' },
    { id: 'wWhat', label: '무엇을', type: 'text', placeholder: '예: 마케팅 책을' },
    { id: 'wHow', label: '어떻게', type: 'text', placeholder: '예: 30분 동안' },
    { id: 'wWhy', label: '왜', type: 'text', placeholder: '예: 성장하기 위해' }
  ];

  function requestNotification() {
    if (!("Notification" in window)) {
      alert("이 브라우저는 알림을 지원하지 않습니다.");
    } else if (Notification.permission === "granted") {
      alert("이미 알림이 허용되어 있습니다!");
    } else if (Notification.permission !== "denied") {
      Notification.requestPermission().then(permission => {
        if (permission === "granted") {
          alert("알림이 활성화되었습니다. 설정한 시간에 알림이 울립니다.");
        }
      });
    }
  }

  // 매 1분마다 시간을 체크해서 알림을 보내는 백그라운드 로직 (그대로 유지)
  setInterval(() => {
    const now = new Date();
    const currentHours = String(now.getHours()).padStart(2, '0');
    const currentMinutes = String(now.getMinutes()).padStart(2, '0');
    const currentTimeStr = `${currentHours}:${currentMinutes}`;
    const todayStr = now.toDateString();

    for (let i = 1; i <= 3; i++) {
      const setTime = localStorage.getItem(`cat${i}_wWhen`);
      const hasExample = localStorage.getItem(`cat${i}_exampleImage`);
      const isSuccess = localStorage.getItem(`cat${i}_isSuccess`);
      const lastAlarmDate = localStorage.getItem(`cat${i}_lastAlarmDate`);

      if (setTime === currentTimeStr && hasExample && isSuccess !== 'true' && lastAlarmDate !== todayStr) {
        if (Notification.permission === "granted") {
          new Notification("🔥 시지프스 클럽 갓생챌린지 PRO", {
            body: `습관 분야 ${i}를 실천할 시간입니다! 지금 바로 정밀 인증해 주세요.`,
            icon: "https://cdn-icons-png.flaticon.com/512/3063/3063822.png" 
          });
        }
        localStorage.setItem(`cat${i}_lastAlarmDate`, todayStr);
      }
    }
  }, 30000); // 30초마다 체크

  // --- Image Handling Utility ---
  // 이미지를 압축하여 로컬스토리지 용량을 아끼고 분석 속도를 높이는 함수
  function compressImage(dataUrl, targetWidth, callback) {
    const img = new Image();
    img.onload = function() {
      const canvas = document.createElement('canvas');
      const MAX_WIDTH = targetWidth || 300; // 정밀 분석용 기본 해상도
      const scaleSize = MAX_WIDTH / img.width;
      canvas.width = MAX_WIDTH;
      canvas.height = img.height * scaleSize;
      
      const ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
      callback(canvas.toDataURL('image/jpeg', 0.6)); // 화질 60%
    }
    img.src = dataUrl;
  }

  // --- Modal Handling ---
  function openModal(title, similarity, mismatch, analysisTime, success, capturedImg) {
    const modal = document.getElementById('resultModal');
    const exampleImgUrl = localStorage.getItem(`modalExampleImgUrl`);

    // 데이터 세팅
    document.getElementById('modalTitle').innerText = title;
    
    // 사진 미리보기 설정
    document.getElementById('modalExamplePhoto').style.backgroundImage = `url(${exampleImgUrl})`;
    document.getElementById('modalResultPhoto').style.backgroundImage = `url(${capturedImg})`;

    const simEl = document.getElementById('modalSimilarity');
    const misEl = document.getElementById('modalMismatch');
    
    simEl.innerText = `${similarity.toFixed(1)}%`;
    misEl.innerText = `${mismatch.toFixed(1)}%`;
    document.getElementById('modalAnalysisTime').innerText = `${(analysisTime / 1000).toFixed(2)}초`;

    // 상태에 따른 스타일 및 메시지
    const msgEl = document.getElementById('modalMessage');
    if (success) {
      modal.querySelector('.modal-content').style.borderColor = 'var(--success)';
      msgEl.innerText = "유사도 기준을 통과했습니다! 챌린지 성공! 🎉";
      msgEl.style.color = "var(--success)";
      simEl.classList.add('high');
      simEl.classList.remove('low');
    } else {
      modal.querySelector('.modal-content').style.borderColor = 'var(--warning)';
      msgEl.innerText = `유사도 기준(50%)에 미달합니다.\n비슷한 구도로 다시 촬영해 주세요!`;
      msgEl.style.color = "var(--warning)";
      simEl.classList.add('low');
      simEl.classList.remove('high');
    }

    modal.classList.add('show');
  }

  function closeModal() {
    const modal = document.getElementById('resultModal');
    modal.classList.remove('show');
  }

  // --- Core Application Logic ---
  function renderHabits() {
    const container = document.getElementById('habitContainer');
    let html = '';

    for (let i = 1; i <= 3; i++) {
      let inputsHtml = fields.map(f => `
        <div class="input-group">
          <label>${f.label}</label>
          <input type="${f.type}" id="cat${i}_${f.id}" placeholder="${f.placeholder}" oninput="checkConditions(${i})">
        </div>
      `).join('');

      html += `
        <div class="habit-section" id="section_${i}">
          <h2 class="habit-title"><i>${habitIcons[i-1]}</i> 습관 분야 ${i}</h2>
          <div class="card">
            <h3>📝 육하원칙 설정</h3>
            ${inputsHtml}
          </div>
          <div class="card">
            <h3>🖼️ 사진 정밀 인증</h3>
            <div class="photo-container">
              <div id="cat${i}_examplePhoto" class="photo-box" onclick="document.getElementById('cat${i}_exampleInput').click()">
                <i>➕</i><br>예시 사진 등록
              </div>
              <div id="cat${i}_resultPhoto" class="photo-box result-box">
                <i>📷</i><br>인증 사진 등록
              </div>
            </div>
            <input type="file" id="cat${i}_exampleInput" accept="image/*" onchange="loadExamplePhoto(event, ${i})">
            <input type="file" id="cat${i}_cameraInput" accept="image/*" capture="environment" onchange="processVerification(event, ${i})">
          </div>
          <button id="cat${i}_practiceBtn" class="action-btn" onclick="document.getElementById('cat${i}_cameraInput').click()" disabled><i>📷</i> 정밀 사진 인증</button>
        </div>
      `;
    }
    container.innerHTML = html;
  }

  window.onload = function() {
    renderHabits();

    const lastSavedDate = localStorage.getItem('lastSavedDate');
    const today = new Date().toDateString();
    const isNewDay = (lastSavedDate !== today);

    if (isNewDay) localStorage.setItem('lastSavedDate', today);

    for (let i = 1; i <= 3; i++) {
      if (isNewDay) {
        localStorage.removeItem(`cat${i}_isSuccess`);
        localStorage.removeItem(`cat${i}_resultImage`);
        localStorage.removeItem(`cat${i}_lastAlarmDate`);
        fields.forEach(f => localStorage.removeItem(`cat${i}_${f.id}`));
      } else {
        fields.forEach(f => {
          const savedVal = localStorage.getItem(`cat${i}_${f.id}`);
          if(savedVal) document.getElementById(`cat${i}_${f.id}`).value = savedVal;
        });
      }

      const savedExample = localStorage.getItem(`cat${i}_exampleImage`);
      if (savedExample) setPhotoBackground(document.getElementById(`cat${i}_examplePhoto`), savedExample);

      if (localStorage.getItem(`cat${i}_isSuccess`) === 'true') {
        const savedResult = localStorage.getItem(`cat${i}_resultImage`);
        if (savedResult) setPhotoBackground(document.getElementById(`cat${i}_resultPhoto`), savedResult);
        setSuccessState(i);
      }
      checkConditions(i);
    }
  };

  function setPhotoBackground(element, imageUrl) {
    element.style.backgroundImage = `url(${imageUrl})`;
    element.innerText = '';
  }

  function checkConditions(catId) {
    let allFilled = true;
    fields.forEach(f => {
      const inputEl = document.getElementById(`cat${catId}_${f.id}`);
      localStorage.setItem(`cat${catId}_${f.id}`, inputEl.value);
      if (inputEl.value.trim() === '') allFilled = false;
    });

    const hasExample = localStorage.getItem(`cat${catId}_exampleImage`) !== null;
    const isSuccess = localStorage.getItem(`cat${catId}_isSuccess`) === 'true';
    const btn = document.getElementById(`cat${catId}_practiceBtn`);

    if (allFilled && hasExample && !isSuccess) btn.disabled = false;
    else btn.disabled = true;
  }

  function loadExamplePhoto(event, catId) {
    const file = event.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = function(e) {
        // 예시 사진 등록 시에도 압축하여 저장 (서버가 없으므로)
        compressImage(e.target.result, 400, function(compressedImg) {
          setPhotoBackground(document.getElementById(`cat${catId}_examplePhoto`), compressedImg);
          localStorage.setItem(`cat${catId}_exampleImage`, compressedImg);
          checkConditions(catId);
        });
      }
      reader.readAsDataURL(file);
    }
  }

  // --- 정밀 유사도 분석 핵심 함수 ---
  function processVerification(event, catId) {
    const file = event.target.files[0];
    if (file) {
      // 1. 화면 전체 로딩 오버레이 활성화
      const overlay = document.getElementById('loadingOverlay');
      overlay.classList.add('show');
      
      const btn = document.getElementById(`cat${catId}_practiceBtn`);
      btn.innerText = "데이터 분석 중... ⚡";
      btn.disabled = true;

      const reader = new FileReader();
      reader.onload = function(e) {
        // 2. 촬영된 사진을 정밀 분석용(300px) 해상도로 압축 (속도와 정확도 균형)
        compressImage(e.target.result, 300, function(capturedImageUrl) {
          const exampleImgUrl = localStorage.getItem(`cat${catId}_exampleImage`);
          localStorage.setItem('modalExampleImgUrl', exampleImgUrl); // 모달용 임시 저장

          // 3. Resemble.js를 이용한 실제 이미지 비교
          const startTime = performance.now(); // 시간 측정
          
          resemble(exampleImgUrl).compareTo(capturedImageUrl)
            .ignoreColors() // 색상 차이보다는 형태/구도에 집중
            .onComplete(function(data) {
              const endTime = performance.now();
              const analysisTime = endTime - startTime;
              
              const similarity = 100 - data.mismatchPercentage;
              const threshold = 50; // 통과 기준 유사도 50%

              // 4. 로딩 오버레이 비활성화
              overlay.classList.remove('show');

              if (similarity >= threshold) {
                // 성공: 결과 모달 오픈
                openModal(`분야 ${catId}: 인증 성공`, similarity, data.mismatchPercentage, analysisTime, true, capturedImageUrl);
                
                setPhotoBackground(document.getElementById(`cat${catId}_resultPhoto`), capturedImageUrl);
                localStorage.setItem(`cat${catId}_resultImage`, capturedImageUrl);
                localStorage.setItem(`cat${catId}_isSuccess`, 'true');
                setSuccessState(catId);
              } else {
                // 실패: 결과 모달 오픈 (사용자에게 데이터로 보여줌)
                openModal(`분야 ${catId}: 인증 실패`, similarity, data.mismatchPercentage, analysisTime, false, capturedImageUrl);
                
                btn.innerText = "정밀 사진 인증";
                btn.disabled = false;
              }
            });
        });
      }
      reader.readAsDataURL(file);
    }
  }

  function setSuccessState(catId) {
    const btn = document.getElementById(`cat${catId}_practiceBtn`);
    btn.innerText = "인증 완료 🎉";
    btn.classList.add('success');
    btn.disabled = true;
    fields.forEach(f => document.getElementById(`cat${catId}_${f.id}`).disabled = true);
  }
</script>

</body>
</html>
